{
  "version": 1,
  "repo_path": "repos",
  "plan": {
    "root": {
      "sort": "version",
      "selectors": [
        { "regex": "^hotfix/.*(?:(\\d+\\.[.\\d]*\\d+)).*" },
        { "regex": "^release/.*(?:(\\d+\\.[.\\d]*\\d+)).*" }
      ],
      "downstream": {
        "develop": {
          "selectors": [{ "name": "develop" }]
        }
      }
    }
  }
}
